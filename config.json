  "history": [
    { "id":1, "year":"2009", "title":"세시소프트 설립 · PC온라인게임 퍼블리싱 시작", "desc":"서울 서초구에서 모바일 게임 퍼블리싱 및 개발 전문 기업으로 창업. 로스트사가 등 PC온라인게임 퍼블리싱 시작.",
      "en":"SESISOFT Founded · PC Online Game Publishing Begins", "en_desc":"Founded as a mobile game publishing & development specialist in Seocho, Seoul. Started PC online game publishing including Lost Saga.",
      "ja":"セシソフト設立・PCオンラインゲームパブリッシング開始", "ja_desc":"ソウル市瑞草区でモバイルゲームパブリッシング・開発専門企業として創業。ロストサガなどPCオンラインゲームのパブリッシングを開始。" },
    { "id":2, "year":"2013", "title":"모바일게임 퍼블리싱 진출", "desc":"모바일게임 퍼블리싱 및 카카오톡 게임 퍼블리싱으로 모바일 시장 본격 진출.",
      "en":"Entered Mobile Game Publishing", "en_desc":"Entered the mobile market in earnest with mobile game publishing and KakaoTalk game publishing.",
      "ja":"モバイルゲームパブリッシングに進出", "ja_desc":"モバイルゲームパブリッシングおよびKakaoTalkゲームパブリッシングでモバイル市場に本格参入。" },
    { "id":3, "year":"2016", "title":"서브컬처 장르 특화 · 대형 파트너십 체결", "desc":"스마일게이트 공동퍼블리싱, DeNA 모바일 게임 공동개발, 반다이남코 마케팅 대행, 사이버에이전트 게임 퍼블리싱 등 글로벌 협력 확대.",
      "en":"Subculture Specialization · Major Partnerships", "en_desc":"Expanded global partnerships: joint publishing with Smilegate, mobile game co-development with DeNA, marketing for Bandai Namco, publishing for CyberAgent games.",
      "ja":"サブカルチャー特化・大型パートナーシップ締結", "ja_desc":"スマイルゲートとの共同パブリッシング、DeNAとのモバイルゲーム共同開発、バンダイナムコのマーケティング代行、サイバーエイジェントのゲームパブリッシングなどグローバル協力を拡大。" },
    { "id":4, "year":"2019", "title":"일본 대형 IP 게임 개발협력", "desc":"프린세스 커넥트(Cygames), 천화백검(DeNA) 등 일본 대형 IP 게임의 국내 개발파트너로 협력. 카카오게임즈와 파트너십 강화.",
      "en":"Japanese Major IP Game Development Partnership", "en_desc":"Partnered as domestic dev partner for major Japanese IP games including Princess Connect (Cygames) and Tenka Hyakken (DeNA). Strengthened partnership with Kakao Games.",
      "ja":"日本大手IPゲーム開発協力", "ja_desc":"プリンセスコネクト（Cygames）、天華百剣（DeNA）などの日本大手IPゲームの国内開発パートナーとして協力。カカオゲームズとのパートナーシップを強化。" },
    { "id":5, "year":"2021", "title":"누적 서비스 40종 돌파 · 조선협객전 출시", "desc":"조선협객전(GNIsoft), 우마무스메(Cygames), 월드 플리퍼(Cygames) 등 다수 타이틀 개발협력으로 기술력 입증.",
      "en":"40+ Titles Milestone · Joseon Hyeokgaekjeon Launch", "en_desc":"Proven technical excellence through co-development of multiple titles including Joseon Hyeokgaekjeon (GNIsoft), Uma Musume (Cygames), World Flipper (Cygames).",
      "ja":"累積40タイトル突破・朝鮮の剣客伝リリース", "ja_desc":"朝鮮の剣客伝（GNIsoft）、ウマ娘（Cygames）、ワールドフリッパー（Cygames）など多数のタイトル開発協力で技術力を実証。" },
    { "id":6, "year":"2022", "title":"천상비M 퍼블리싱 · 누적 50종 달성", "desc":"레트로 IP MMORPG 천상비M 직접 퍼블리싱. 우마무스메 국내 서비스로 Google Play 차트 상위권 달성.",
      "en":"Cheongsangbi M Publishing · 50 Titles Achieved", "en_desc":"Directly published retro IP MMORPG Cheongsangbi M. Achieved top Google Play chart ranking through Uma Musume domestic service.",
      "ja":"天上秘Mパブリッシング・累積50タイトル達成", "ja_desc":"レトロIPのMMORPG「天上秘M」を直接パブリッシング。ウマ娘の国内サービスでGoogle Playチャート上位を達成。" },
    { "id":7, "year":"2023", "title":"텐센트 글로벌 런칭게임 서비스 협력", "desc":"언던(Undawn) 한국 출시로 Google Play 인기순위 1위 달성. 드래곤네스트2, Synced 등 텐센트 글로벌 타이틀 서비스 협력. 뿌요뿌요!!퀘스트(SEGA) 퍼블리싱.",
      "en":"Tencent Global Launch Game Partnership", "en_desc":"Achieved #1 on Google Play popularity with Undawn Korea launch. Partnered on Tencent global titles Dragon Nest 2 and Synced. Published Puyo Puyo!! Quest (SEGA).",
      "ja":"テンセントグローバルゲームサービス協力", "ja_desc":"アンドーン（Undawn）韓国リリースでGoogle Play人気ランキング1位を達成。ドラゴンネスト2、Syncedなどテンセントのグローバルタイトルのサービスに協力。ぷよぷよ！！クエスト（SEGA）をパブリッシング。" },
    { "id":8, "year":"2025", "title":"자체 PC MMORPG 서비스 · 글로벌 사업 강화", "desc":"CarpeDiem, WindSlayer 등 자체 PC MMORPG 퍼블리싱. ARD : BlackStone(Horizon) 모바일 MMORPG 서비스. 글로벌 파트너십 30개사 이상으로 확대.",
      "en":"Own PC MMORPG Service · Strengthening Global Business", "en_desc":"Publishing own PC MMORPGs CarpeDiem and WindSlayer. Servicing mobile MMORPG ARD: BlackStone (Horizon). Expanded to 30+ global partnerships.",
      "ja":"自社PC MMORPGサービス・グローバル事業強化", "ja_desc":"CarpeDiem、WindSlayerなど自社PC MMORPGをパブリッシング。モバイルMMORPG ARD：BlackStone（Horizon）をサービス。グローバルパートナーシップを30社以上に拡大。" }
